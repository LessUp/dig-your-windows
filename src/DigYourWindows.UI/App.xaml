<Application x:Class="DigYourWindows.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DigYourWindows.UI"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:DigYourWindows.UI.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Standard Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
            <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>

            <!-- Null-Safe Converters -->
            <conv:NullToEmptyStringConverter x:Key="NullToEmptyStringConverter"/>
            <conv:NullToPlaceholderConverter x:Key="NullToPlaceholderConverter"/>
            <conv:NullableDoubleToStringConverter x:Key="NullableDoubleToStringConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
